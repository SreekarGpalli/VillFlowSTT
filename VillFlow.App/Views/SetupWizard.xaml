<Window x:Class="VillFlow.App.Views.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VillFlow Setup"
        Width="560" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Step content area -->
        <Grid x:Name="StepContainer" Grid.Row="0" Margin="32,24">
            
            <!-- Step 1: Welcome -->
            <StackPanel x:Name="Step1" Visibility="Visible">
                <TextBlock Text="🎙  Welcome to VillFlow" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,20,0,16" />
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" LineHeight="22">
                    VillFlow is a lightning-fast voice dictation tool. Hold your hotkey, speak,
                    and your words appear wherever your cursor is — corrected and polished.
                </TextBlock>

                <Border Background="#2A2A42" CornerRadius="8" Padding="14,12" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource AccentCyanBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6">
                            ⚡ Built for Groq — 100% Free
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" LineHeight="20">
                            VillFlow is built primarily for Groq's blazing-fast API, which is completely free.
                            Get your API key in seconds:
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource AccentCyanBrush}" FontSize="13" Margin="0,6,0,0"
                                   Cursor="Hand" x:Name="GroqLink" MouseDown="OnGroqLinkClick"
                                   TextDecorations="Underline">
                            👉  console.groq.com → Create Free API Key
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"
                           LineHeight="22" Margin="0,16,0,0">
                    Let's get you set up in under 2 minutes.
                </TextBlock>
            </StackPanel>

            <!-- Step 2: Microphone -->
            <StackPanel x:Name="Step2" Visibility="Collapsed">
                <TextBlock Text="🎤  Select Microphone" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,20,0,16" />
                <TextBlock Text="Choose the microphone VillFlow should use for recording."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />
                <ComboBox x:Name="WizMicCombo" Style="{StaticResource DarkComboBox}" Width="350"
                          HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Step 3: Hotkey -->
            <StackPanel x:Name="Step3" Visibility="Collapsed">
                <TextBlock Text="⌨️  Set Hotkey" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,20,0,16" />
                <TextBlock Text="Hold this hotkey to record, release to transcribe. Default is Ctrl+Space."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="WizHotkeyDisplay" Style="{StaticResource DarkTextBox}"
                             IsReadOnly="True" Width="160" Text="Ctrl + Space" />
                    <Button Content="Change" Style="{StaticResource PrimaryButton}"
                            x:Name="WizChangeHotkeyBtn" Click="OnWizChangeHotkey" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock Text="Tip: If you use a USB foot pedal, bind it to the same key."
                           Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic"
                           Margin="0,16,0,0" FontSize="12" />
            </StackPanel>

            <!-- Step 4: STT -->
            <StackPanel x:Name="Step4" Visibility="Collapsed">
                <TextBlock Text="🗣️  Transcription (STT)" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,20,0,12" />
                <TextBlock Text="Set up your primary speech-to-text provider. You can add fallbacks later in Settings."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Provider" Grid.Row="0" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <ComboBox x:Name="WizSttProvider" Grid.Row="0" Grid.Column="1"
                              Style="{StaticResource DarkComboBox}" SelectionChanged="OnWizSttProviderChanged" />

                    <TextBlock Text="API Key" Grid.Row="1" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBox x:Name="WizSttKey" Grid.Row="1" Grid.Column="1" Style="{StaticResource DarkTextBox}" />

                    <TextBlock Text="Endpoint" Grid.Row="2" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1">
                        <TextBox x:Name="WizSttUrl" Style="{StaticResource DarkTextBox}" Width="250" />
                        <Button Content="Fetch" Style="{StaticResource PrimaryButton}"
                                Click="OnWizFetchSttModels" Margin="6,0,0,0" />
                    </StackPanel>

                    <TextBlock Text="Model" Grid.Row="3" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <ComboBox x:Name="WizSttModel" Grid.Row="3" Grid.Column="1" Style="{StaticResource DarkComboBox}" />
                </Grid>

                <TextBlock x:Name="WizSttNote" Text="" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" FontStyle="Italic" Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 5: Polish -->
            <StackPanel x:Name="Step5" Visibility="Collapsed">
                <TextBlock Text="✨  Text Polish (Optional)" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,20,0,12" />
                <CheckBox x:Name="WizPolishToggle" Content="Enable AI text polishing"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"
                          IsChecked="True" />

                <Grid x:Name="WizPolishGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="36" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Provider" Grid.Row="0" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <ComboBox x:Name="WizPolishProvider" Grid.Row="0" Grid.Column="1"
                              Style="{StaticResource DarkComboBox}" SelectionChanged="OnWizPolishProviderChanged" />

                    <TextBlock Text="API Key" Grid.Row="1" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBox x:Name="WizPolishKey" Grid.Row="1" Grid.Column="1" Style="{StaticResource DarkTextBox}" />

                    <TextBlock Text="Endpoint" Grid.Row="2" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1">
                        <TextBox x:Name="WizPolishUrl" Style="{StaticResource DarkTextBox}" Width="250" />
                        <Button Content="Fetch" Style="{StaticResource PrimaryButton}"
                                Click="OnWizFetchPolishModels" Margin="6,0,0,0" />
                    </StackPanel>

                    <TextBlock Text="Model" Grid.Row="3" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <ComboBox x:Name="WizPolishModel" Grid.Row="3" Grid.Column="1" Style="{StaticResource DarkComboBox}" />
                </Grid>
            </StackPanel>

            <!-- Step 6: Done -->
            <StackPanel x:Name="Step6" Visibility="Collapsed">
                <TextBlock Text="✅  You're All Set!" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource AccentGreenBrush}" Margin="0,40,0,16" />
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" LineHeight="22">
                    VillFlow is ready. Hold your hotkey to start dictating.
                    Right-click the tray icon to access Settings or quit.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                           LineHeight="22" Margin="0,16,0,0">
                    You can always re-run this wizard from the tray menu.
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="32,0,32,20">
            <Button x:Name="BackBtn" Content="Back" Style="{StaticResource PrimaryButton}"
                    Background="#2A4A7F" Click="OnBack" Margin="0,0,8,0" Visibility="Collapsed" />
            <Button x:Name="NextBtn" Content="Next" Style="{StaticResource PrimaryButton}"
                    Click="OnNext" Width="100" />
        </StackPanel>

        <!-- Step indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left"
                    Margin="32,0,0,24">
            <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="0,0,6,0" />
            <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="0,0,6,0" />
            <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="0,0,6,0" />
            <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="0,0,6,0" />
            <Ellipse x:Name="Dot5" Width="8" Height="8" Margin="0,0,6,0" />
            <Ellipse x:Name="Dot6" Width="8" Height="8" Margin="0,0,6,0" />
        </StackPanel>
    </Grid>
</Window>
