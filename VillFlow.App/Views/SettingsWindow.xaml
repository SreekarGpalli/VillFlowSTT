<Window x:Class="VillFlow.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VillFlow Settings"
        Width="520" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Margin="0,0,12,0">
            
            <!-- Header -->
            <TextBlock Text="🎙  VillFlow Settings" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24" />

            <!-- ════ RECORDING ════ -->
            <TextBlock Text="RECORDING" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,12" />

            <!-- Microphone -->
            <TextBlock Text="Microphone" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="MicCombo" Style="{StaticResource DarkComboBox}" Margin="0,0,0,16" />

            <!-- Hotkey -->
            <TextBlock Text="Hotkey (hold to record)" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBox x:Name="HotkeyDisplay" Style="{StaticResource DarkTextBox}"
                         IsReadOnly="True" Width="160" Text="Ctrl + Space" />
                <Button Content="Change" Style="{StaticResource PrimaryButton}"
                        x:Name="ChangeHotkeyBtn" Click="OnChangeHotkey" Margin="8,0,0,0" />
            </StackPanel>

            <Separator Margin="0,0,0,20" />

            <!-- ════ TRANSCRIPTION (STT) ════ -->
            <TextBlock Text="TRANSCRIPTION" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />

            <!-- Primary STT Slot -->
            <TextBlock Text="Primary" FontWeight="SemiBold" Foreground="{StaticResource AccentCyanBrush}"
                       Margin="0,0,0,4" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Text="Provider" Grid.Row="0" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <ComboBox x:Name="SttPrimaryProvider" Grid.Row="0" Grid.Column="1"
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,6" SelectionChanged="OnSttProviderChanged" Tag="0" />

                <TextBlock Text="API Key" Grid.Row="1" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <TextBox x:Name="SttPrimaryKey" Grid.Row="1" Grid.Column="1"
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,6" />

                <TextBlock Text="Endpoint" Grid.Row="2" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                    <TextBox x:Name="SttPrimaryUrl" Style="{StaticResource DarkTextBox}" Width="260" />
                    <Button Content="Fetch Models" Style="{StaticResource PrimaryButton}"
                            x:Name="SttPrimaryFetch" Click="OnFetchSttModels" Tag="0" Margin="8,0,0,0" />
                </StackPanel>

                <TextBlock Text="Model" Grid.Row="3" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <ComboBox x:Name="SttPrimaryModel" Grid.Row="3" Grid.Column="1"
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,6" />
            </Grid>

            <!-- Fallback Slots (dynamically shown) -->
            <StackPanel x:Name="FallbacksPanel" Margin="0,0,0,8">
                <!-- Fallback slots are added programmatically -->
            </StackPanel>

            <Button Content="+ Add Fallback" x:Name="AddFallbackBtn" Style="{StaticResource PrimaryButton}"
                    Click="OnAddFallback" HorizontalAlignment="Left" Margin="0,0,0,20"
                    Background="#2A4A7F" />

            <Separator Background="#2A4A7F" Margin="0,0,0,20" />

            <!-- ════ TEXT POLISH ════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="TEXT POLISH" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <CheckBox x:Name="PolishToggle" Content="Enabled"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="16,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <Grid x:Name="PolishPanel" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Text="Provider" Grid.Row="0" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <ComboBox x:Name="PolishProviderCombo" Grid.Row="0" Grid.Column="1"
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,6" SelectionChanged="OnPolishProviderChanged" />

                <TextBlock Text="API Key" Grid.Row="1" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <TextBox x:Name="PolishKeyBox" Grid.Row="1" Grid.Column="1"
                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,6" />

                <TextBlock Text="Endpoint" Grid.Row="2" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                    <TextBox x:Name="PolishUrlBox" Style="{StaticResource DarkTextBox}" Width="260" />
                    <Button Content="Fetch Models" Style="{StaticResource PrimaryButton}"
                            Click="OnFetchPolishModels" Margin="8,0,0,0" />
                </StackPanel>

                <TextBlock Text="Model" Grid.Row="3" Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <ComboBox x:Name="PolishModelCombo" Grid.Row="3" Grid.Column="1"
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,6" />
            </Grid>

            <!-- System Prompt -->
            <TextBlock Text="System Prompt" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,4" />
            <TextBox x:Name="SystemPromptBox" Style="{StaticResource DarkTextBox}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="100" Margin="0,0,0,24" />

            <!-- Save Button -->
            <Button Content="Save Settings" Style="{StaticResource PrimaryButton}"
                    Click="OnSave" HorizontalAlignment="Right" Width="140" Margin="0,0,0,16" />
        </StackPanel>
    </ScrollViewer>
</Window>
