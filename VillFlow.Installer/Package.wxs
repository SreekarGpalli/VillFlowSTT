<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Id="VillFlowPackage"
           Name="VillFlow"
           Manufacturer="VillFlow"
           Version="1.0.0"
           UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
    <MediaTemplate EmbedCab="yes" />
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="VillFlow" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="VillFlow" />
    </StandardDirectory>
    <ComponentGroup Id="VillFlowComponents">
      <Component Id="VillFlowApp" Guid="b2c3d4e5-f6a7-8901-bcde-f12345678901" Directory="INSTALLFOLDER">
        <File Id="VillFlowExe"
              Source="$(var.PublishPath)VillFlow.App.exe"
              KeyPath="yes">
          <Shortcut Id="VillFlowStartMenuShortcut"
                    Name="VillFlow"
                    Description="Voice dictation — hold Ctrl+Space to record"
                    Directory="ApplicationProgramsFolder"
                    WorkingDirectory="INSTALLFOLDER" />
        </File>
      </Component>
      <Component Id="StartMenuShortcuts" Guid="c3d4e5f6-a7b8-9012-cdef-123456789012" Directory="ApplicationProgramsFolder">
        <RemoveFolder Id="RemoveAppProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\VillFlow" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
    <Feature Id="Main" Title="VillFlow" Level="1">
      <ComponentGroupRef Id="VillFlowComponents" />
    </Feature>
  </Package>
</Wix>
